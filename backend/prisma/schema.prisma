generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SegmentType {
  DYNAMIC
  FROZEN
}

enum DeltaChangeType {
  ADDED
  REMOVED
}

enum EvaluationTriggerType {
  TRANSACTION
  PROFILE_UPDATE
  TIME_ADVANCE
  DEPENDENCY_CHANGE
  MANUAL_REFRESH
  INITIAL_SEED
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  city      String?
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  memberships  SegmentMembershipCurrent[]
  deltaItems   SegmentDeltaItem[]
}

model Transaction {
  id         String   @id @default(cuid())
  customerId String
  amount     Decimal  @db.Decimal(12, 2)
  occurredAt DateTime
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([occurredAt])
}

model Segment {
  id                  String      @id @default(cuid())
  name                String      @unique
  type                SegmentType
  ruleJson            Json
  lastEvaluatedAt     DateTime?
  lastSnapshotVersion Int         @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  memberships       SegmentMembershipCurrent[]
  deltas            SegmentDelta[]
  dependencies      SegmentDependency[]        @relation("SegmentDependencies")
  usedBy            SegmentDependency[]        @relation("SegmentDependents")
  segmentDeltaItems SegmentDeltaItem[]
}

model SegmentDependency {
  id                 String @id @default(cuid())
  segmentId          String
  dependsOnSegmentId String

  segment          Segment @relation("SegmentDependencies", fields: [segmentId], references: [id], onDelete: Cascade)
  dependsOnSegment Segment @relation("SegmentDependents", fields: [dependsOnSegmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, dependsOnSegmentId])
  @@index([segmentId])
  @@index([dependsOnSegmentId])
}

model SegmentMembershipCurrent {
  id         String   @id @default(cuid())
  segmentId  String
  customerId String
  updatedAt  DateTime @default(now())

  segment  Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([segmentId, customerId])
  @@index([segmentId])
  @@index([customerId])
}

model SegmentDelta {
  id           String                @id @default(cuid())
  segmentId    String
  fromVersion  Int
  toVersion    Int
  addedCount   Int                   @default(0)
  removedCount Int                   @default(0)
  triggerType  EvaluationTriggerType
  createdAt    DateTime              @default(now())

  segment Segment            @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  items   SegmentDeltaItem[]

  @@index([segmentId])
  @@index([createdAt])
}

model SegmentDeltaItem {
  id         String          @id @default(cuid())
  deltaId    String
  customerId String
  changeType DeltaChangeType

  delta     SegmentDelta @relation(fields: [deltaId], references: [id], onDelete: Cascade)
  customer  Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  segment   Segment?     @relation(fields: [segmentId], references: [id])
  segmentId String?

  @@index([deltaId])
  @@index([customerId])
}

model SimulationState {
  id           String   @id
  currentTime  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}